<Window x:Class="financial_planner.View.AddIncomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:financial_planner.ViewModels"
        WindowState="Maximized"
        WindowStyle="None"
        Title="Внесение дохода" Height="450" Width="800">

    <Window.DataContext>
        <vm:AddIncomeViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель навигации -->
        <Grid Grid.Column="0" Background="#BBDEFB">
            <StackPanel Margin="0,40,0,0">
                <TextBlock Text="ФИНАНСЫ" FontSize="20" FontWeight="Bold" 
                           Foreground="#0D47A1" HorizontalAlignment="Center" Margin="0,20,0,30"/>

                <Button Content="Помощь" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding HelpCommand}"/>

                <Button Content="Внести расход" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Click="ButtonAddExpense_Click"/>

                <Button Content="Мои цели" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Click="ButtonGoals_Click"/>

                <Button Content="Новая цель" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Click="ButtonNewGoal_Click"/>

                <Button Content="Назад" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Click="ButtonBack_Click"/>

                <Button Content="Выйти" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Click="ButtonExit_Click"/>
            </StackPanel>
        </Grid>

        <!-- Правая область: форма внесения дохода -->
        <Grid Grid.Column="1" Background="#E3F2FD" Margin="30,25,30,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="ВНЕСЕНИЕ ДОХОДА" FontSize="22" FontWeight="SemiBold" 
                       Foreground="#0D47A1" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <StackPanel Grid.Row="1" Margin="50,0">
                <TextBlock Text="Сумма к внесению" FontSize="14" Foreground="#0D47A1" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" 
                         Height="40" FontSize="14" Padding="10"
                         Background="White" BorderBrush="#42A5F5" BorderThickness="1"/>

                <TextBlock Text="Из них к уплате налога" FontSize="14" Foreground="#0D47A1" Margin="0,15,0,5"/>
                <TextBox Text="{Binding TaxText, Mode=OneWay}" Height="40" FontSize="14" Padding="10"
                         BorderBrush="#42A5F5" BorderThickness="1" IsReadOnly="True" Background="#F5F5F5"/>

                <TextBlock Text="Источник денежных средств" FontSize="14" Foreground="#0D47A1" Margin="0,15,0,5"/>
                <ComboBox ItemsSource="{Binding IncomeCategories}"
                          SelectedItem="{Binding SelectedCategory}"
                          DisplayMemberPath="Name"
                          Height="40" FontSize="14" Padding="8"
                          Background="White" BorderBrush="#42A5F5" BorderThickness="1"/>

                <TextBlock Text="Заметки" FontSize="14" Foreground="#0D47A1" Margin="0,15,0,5"/>
                <TextBox Text="{Binding Note}" Height="60" FontSize="14" Padding="10"
                         Background="White" BorderBrush="#42A5F5" BorderThickness="1"
                         TextWrapping="Wrap" AcceptsReturn="True"/>

                <TextBlock Text="Дата" FontSize="14" Foreground="#0D47A1" Margin="0,15,0,5"/>
                <DatePicker SelectedDate="{Binding SelectedDate}" Height="40" FontSize="14"
                            Background="White" BorderBrush="#42A5F5" BorderThickness="1"/>

                <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="Red" 
                           Margin="0,10,0,0" Visibility="{Binding ErrorMessage, TargetNullValue=Collapsed, FallbackValue=Collapsed}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                    <Button Content="Сохранить" Width="120" Height="40"
                            Background="#4CAF50" Foreground="White" BorderThickness="0"
                            FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                            Command="{Binding SaveCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                    <Button Content="Отмена" Width="100" Height="40" Margin="15,0,0,0"
                            Background="#90A4AE" Foreground="White" BorderThickness="0"
                            FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                            Command="{Binding CancelCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                    <Button Content="Архив" Width="100" Height="40" Margin="15,0,0,0"
                            Background="#42A5F5" Foreground="White" BorderThickness="0"
                            FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                            Command="{Binding ArchiveCommand}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>