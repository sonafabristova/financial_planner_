<Window x:Class="financial_planner.View.AuthorizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowState="Maximized"
        WindowStyle="None"
        Title="Авторизация" Height="450" Width="800">
    <Grid Background="#E3F2FD">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,80,130,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Логин" Foreground="#0D47A1" FontSize="14"/>
                <TextBox Margin="20,5,15,10" Width="150" Name="BoxLogin" 
                         Background="White" BorderBrush="#42A5F5" FontSize="14"/>
            </StackPanel>
            <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                <TextBlock Text="Пароль" Foreground="#0D47A1" FontSize="14"/>
                <PasswordBox Margin="12,5,15,10" Width="150" Name="BoxPass" 
                             Background="White" BorderBrush="#42A5F5" FontSize="14"/>
            </StackPanel>
            <StackPanel Margin="0,15,0,0" Orientation="Horizontal">
                <Button Margin="0,5,20,0" Width="100" Height="30" Content="Войти" 
                        Name="ButtonLogin" Click="ButtonLogin_Click" 
                        Background="#42A5F5" Foreground="White" BorderThickness="0"/>
                <Button Margin="0,5,0,0" Content="Регистрация" Height="30" Width="100"
                        Name="ButtonRegister" Click="ButtonRegister_Click" 
                        Background="#90CAF9" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </StackPanel>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top">
            <TextBlock Text="ФИНАНСОВЫЙ ПЛАНИРОВЩИК" Margin="10,160,150,10" 
                       FontSize="28" FontWeight="Bold" Foreground="#0D47A1"/>
        </StackPanel>
    </Grid>
</Window>