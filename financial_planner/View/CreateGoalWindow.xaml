<Window x:Class="financial_planner.View.CreateGoalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:financial_planner.ViewModels"
        WindowState="Maximized"
        WindowStyle="None"
        Title="Создание цели" Height="550" Width="800">

    <Window.DataContext>
        <vm:CreateGoalViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель навигации -->
        <Grid Grid.Column="0" Background="#BBDEFB">
            <StackPanel Margin="0,40,0,0">
                <TextBlock Text="ФИНАНСЫ" FontSize="20" FontWeight="Bold" 
                           Foreground="#0D47A1" HorizontalAlignment="Center" Margin="0,20,0,30"/>

                <Button Content="Помощь" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding HelpCommand}"/>

                <Button Content="Внести доход" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Click="ButtonAddIncome_Click"/>

                <Button Content="Внести расход" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Click="ButtonAddExpense_Click"/>

                <Button Content="Мои цели" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Click="ButtonGoals_Click"/>

                <Button Content="Назад" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Click="ButtonBack_Click"/>

                <Button Content="Выйти" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Click="ButtonExit_Click"/>
            </StackPanel>
        </Grid>

        <!-- Правая область: форма создания цели -->
        <Grid Grid.Column="1" Background="#E3F2FD" Margin="30,25,30,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="НОВАЯ ЦЕЛЬ НАКОПЛЕНИЯ" FontSize="22" FontWeight="SemiBold" 
                       Foreground="#0D47A1" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="50,0">
                    <TextBlock Text="Название цели" FontSize="14" Foreground="#0D47A1" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                             Height="40" FontSize="14" Padding="10"
                             Background="White" BorderBrush="#42A5F5" BorderThickness="1"/>

                    <TextBlock Text="Описание" FontSize="14" Foreground="#0D47A1" Margin="0,15,0,5"/>
                    <TextBox Text="{Binding Description}" Height="60" FontSize="14" Padding="10"
                             Background="White" BorderBrush="#42A5F5" BorderThickness="1"
                             TextWrapping="Wrap" AcceptsReturn="True"/>

                    <TextBlock Text="Целевая сумма" FontSize="14" Foreground="#0D47A1" Margin="0,15,0,5"/>
                    <TextBox Text="{Binding TargetAmount, UpdateSourceTrigger=PropertyChanged}" 
                             Height="40" FontSize="14" Padding="10"
                             Background="White" BorderBrush="#42A5F5" BorderThickness="1"/>

                    <TextBlock Text="Приоритет" FontSize="14" Foreground="#0D47A1" Margin="0,15,0,5"/>
                    <ComboBox ItemsSource="{Binding Priorities}"
                              SelectedItem="{Binding SelectedPriority}"
                              DisplayMemberPath="Name"
                              Height="40" FontSize="14" Padding="8"
                              Background="White" BorderBrush="#42A5F5" BorderThickness="1"/>

                    <TextBlock Text="Процент отчислений" FontSize="14" Foreground="#0D47A1" Margin="0,15,0,5"/>
                    <TextBox Text="{Binding AllocationPercentage, UpdateSourceTrigger=PropertyChanged}" 
                             Height="40" FontSize="14" Padding="10"
                             Background="White" BorderBrush="#42A5F5" BorderThickness="1"/>

                    <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="Red" 
                               Margin="0,10,0,0" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,20">
                        <Button Content="Создать цель" Width="120" Height="40"
                                Background="#4CAF50" Foreground="White" BorderThickness="0"
                                FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                                Command="{Binding CreateCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                        <Button Content="Отмена" Width="100" Height="40" Margin="15,0,0,0"
                                Background="#90A4AE" Foreground="White" BorderThickness="0"
                                FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                                Command="{Binding CancelCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>