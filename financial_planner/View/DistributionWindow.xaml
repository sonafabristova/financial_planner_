<Window x:Class="financial_planner.View.DistributionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:financial_planner.ViewModels"
        WindowState="Maximized"
        WindowStyle="None"
        Title="Распределение средств" Height="450" Width="800">

   

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель навигации -->
        <Grid Grid.Column="0" Background="#BBDEFB">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,40,0,0">
                <TextBlock Text="ФИНАНСЫ" FontSize="20" FontWeight="Bold" 
                           Foreground="#0D47A1" HorizontalAlignment="Center" Margin="0,20,0,30"/>

                <Button Content="Помощь" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding HelpCommand}"/>

                <Button Content="Внести доход" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding AddIncomeCommand}"/>

                <Button Content="Внести расход" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding AddExpenseCommand}"/>

                <Button Content="Мои цели" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding GoalsCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>

                <Button Content="Новая цель" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding NewGoalCommand}"/>

                <Rectangle Height="1" Margin="15,20,15,10" Fill="#90CAF9" Opacity="0.5"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,30">
                <Button Content="Назад" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding BackCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>

                <Button Content="Выйти" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding ExitCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Правая область -->
        <Grid Grid.Column="1" Background="#E3F2FD" Margin="20,25,25,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="РАСПРЕДЕЛЕНИЕ СРЕДСТВ" FontSize="24" FontWeight="Bold" 
                       Foreground="#0D47A1" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="СВОБОДНЫЕ СРЕДСТВА" FontSize="11" Foreground="#78909C" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding FreeBalanceText}" FontSize="28" FontWeight="Bold" 
                               Foreground="#4CAF50" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2" Text="ПРЕДЛОЖЕНИЕ ПО РАСПРЕДЕЛЕНИЮ" FontSize="14" FontWeight="SemiBold" 
                       Foreground="#0D47A1" Margin="0,0,0,10"/>

            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DistributionItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="8" Padding="12,10" Margin="0,0,0,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding GoalName}" FontWeight="Bold" Foreground="#0D47A1"/>
                                        <TextBlock Text="{Binding PriorityName}" FontSize="11" Foreground="#78909C"/>
                                        <TextBlock Text="{Binding Remaining, StringFormat=Осталось: {0:N0} ₽}" 
                                                   FontSize="10" Foreground="#90A4AE"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding SuggestedAmount, StringFormat={}{0:N0} ₽}" 
                                                   FontWeight="Bold" FontSize="16" Foreground="#4CAF50"/>
                                        <TextBlock Text="{Binding Percentage, StringFormat={}{0}%}" 
                                                   FontSize="11" Foreground="#78909C"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button Content="Внести суммы в накопления" Width="220" Height="45"
                        Background="#4CAF50" Foreground="White" BorderThickness="0"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding ApplyCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                        IsEnabled="{Binding CanApply}"/>
                <Button Content="Отмена" Width="100" Height="45" Margin="15,0,0,0"
                        Background="#90A4AE" Foreground="White" BorderThickness="0"
                        FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>