<Window x:Class="financial_planner.View.DistributionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowState="Maximized"
        WindowStyle="None"
        Title="Распределение средств" Height="450" Width="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель навигации -->
        <Grid Grid.Column="0" Background="#BBDEFB">
            <StackPanel Margin="0,40,0,0">
                <TextBlock Text="ФИНАНСЫ" FontSize="20" FontWeight="Bold" 
                           Foreground="#0D47A1" HorizontalAlignment="Center" 
                           Margin="0,20,0,30"/>

                <Button Content="Помощь" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" 
                        BorderThickness="0" HorizontalAlignment="Left" 
                        FontSize="14" Cursor="Hand" Click="ButtonHelp_Click"/>

                <Button Content="Внести доход" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" 
                        BorderThickness="0" HorizontalAlignment="Left" 
                        FontSize="14" Cursor="Hand" Click="ButtonAddIncome_Click"/>

                <Button Content="Внести расход" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" 
                        BorderThickness="0" HorizontalAlignment="Left" 
                        FontSize="14" Cursor="Hand" Click="ButtonAddExpense_Click"/>

                <Button Content="Мои цели" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" 
                        BorderThickness="0" HorizontalAlignment="Left" 
                        FontSize="14" Cursor="Hand" Click="ButtonGoals_Click"/>

                <Button Content="Новая цель" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" 
                        BorderThickness="0" HorizontalAlignment="Left" 
                        FontSize="14" Cursor="Hand" Click="ButtonNewGoal_Click"/>

                <Button Content="Назад" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" 
                        BorderThickness="0" HorizontalAlignment="Left" 
                        FontSize="14" Cursor="Hand" Click="ButtonBack_Click"/>

                <Button Content="Выйти" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" 
                        BorderThickness="0" HorizontalAlignment="Left" 
                        FontSize="14" Cursor="Hand" Click="ButtonExit_Click"/>
            </StackPanel>
        </Grid>

        <!-- Правая область: распределение средств -->
        <Grid Grid.Column="1" Background="#E3F2FD" Margin="20,25,25,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0" Text="РАСПРЕДЕЛЕНИЕ СРЕДСТВ" 
                       FontSize="24" FontWeight="Bold" 
                       Foreground="#0D47A1" HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <!-- Свободные средства -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" 
                    Padding="15,12" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="СВОБОДНЫЕ СРЕДСТВА" FontSize="12" 
                               Foreground="#78909C" FontWeight="SemiBold"/>
                    <TextBlock x:Name="FreeBalanceText" FontSize="32" FontWeight="Bold" 
                               Foreground="#4CAF50" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Заголовок списка -->
            <TextBlock Grid.Row="2" Text="ПРЕДЛОЖЕНИЕ ПО РАСПРЕДЕЛЕНИЮ" 
                       FontSize="14" FontWeight="SemiBold" 
                       Foreground="#0D47A1" Margin="0,0,0,12"/>

            <!-- Список распределения (занимает всё свободное место) -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="DistributionList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="10" 
                                    Padding="15,12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding GoalName}" 
                                                   FontWeight="Bold" FontSize="15"
                                                   Foreground="#0D47A1"/>
                                        <TextBlock Text="{Binding PriorityName}" 
                                                   FontSize="11" Foreground="#78909C"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding SuggestedAmount, StringFormat={}{0:N0} ₽}" 
                                                   FontWeight="Bold" FontSize="16"
                                                   Foreground="#4CAF50"/>
                                        <TextBlock Text="{Binding Percentage, StringFormat={}{0}% от свободных}" 
                                                   FontSize="11" Foreground="#78909C"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Кнопки (в самом низу) -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" 
                        HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button x:Name="ApplyButton" Content="Внести суммы в накопления" 
                        Width="220" Height="45" 
                        Background="#4CAF50" Foreground="White" BorderThickness="0"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                        Click="ButtonApply_Click"/>
                <Button Content="Отмена" Width="100" Height="45" Margin="15,0,0,0"
                        Background="#90A4AE" Foreground="White" BorderThickness="0"
                        FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                        Click="ButtonCancel_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>