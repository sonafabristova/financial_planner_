<Window x:Class="financial_planner.View.GoalCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка цели" 
        Height="800" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Background="#E3F2FD">
        <StackPanel Margin="20">
            <TextBlock Text="КАРТОЧКА ЦЕЛИ" FontSize="22" FontWeight="Bold" 
                       Foreground="#0D47A1" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="НАЗВАНИЕ" FontSize="11" Foreground="#78909C"/>
                    <TextBlock x:Name="NameText" FontSize="18" FontWeight="Bold" Foreground="#0D47A1" Margin="0,5,0,10"/>

                    <TextBlock Text="ОПИСАНИЕ" FontSize="11" Foreground="#78909C"/>
                    <TextBlock x:Name="DescriptionText" FontSize="14" Foreground="#5C6BC0" Margin="0,5,0,10" TextWrapping="Wrap"/>

                    <TextBlock Text="СТАТУС" FontSize="11" Foreground="#78909C"/>
                    <Border x:Name="StatusBorder" CornerRadius="10" Padding="8,4" Margin="0,5,0,10" HorizontalAlignment="Left">
                        <TextBlock x:Name="StatusText" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                    </Border>

                    <TextBlock Text="ПРИОРИТЕТ" FontSize="11" Foreground="#78909C"/>
                    <TextBlock x:Name="PriorityText" FontSize="14" FontWeight="SemiBold" Foreground="#1565C0" Margin="0,5,0,10"/>

                    <TextBlock Text="ПРОЦЕНТ ОТЧИСЛЕНИЙ" FontSize="11" Foreground="#78909C"/>
                    <TextBlock x:Name="PercentageText" FontSize="14" FontWeight="SemiBold" Foreground="#4CAF50" Margin="0,5,0,10"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="ФИНАНСЫ" FontSize="12" FontWeight="SemiBold" Foreground="#0D47A1" Margin="0,0,0,10"/>
                    <TextBlock x:Name="TargetAmountText" FontSize="14" Margin="0,3"/>
                    <TextBlock x:Name="CurrentAmountText" FontSize="14" Margin="0,3"/>
                    <TextBlock x:Name="RemainingText" FontSize="14" Margin="0,3"/>
                    <!-- ИСПРАВЛЕНО: добавлен Mode=OneWay -->
                    <ProgressBar x:Name="ProgressBar" Value="{Binding Progress, Mode=OneWay}" Maximum="100" Height="8" Margin="0,10,0,0" Foreground="#42A5F5" Background="#E0E0E0"/>
                    <TextBlock x:Name="ProgressText" FontSize="11" Foreground="#78909C" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="ИСТОРИЯ" FontSize="12" FontWeight="SemiBold" Foreground="#0D47A1" Margin="0,0,0,10"/>
                    <TextBlock x:Name="CreatedDateText" FontSize="12" Foreground="#78909C"/>
                    <TextBlock x:Name="CompletedDateText" FontSize="12" Foreground="#78909C" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Button Content="Закрыть" Width="120" Height="35" HorizontalAlignment="Center"
                    Background="#42A5F5" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold" Cursor="Hand" Click="ButtonClose_Click"/>
        </StackPanel>
    </Grid>
</Window>