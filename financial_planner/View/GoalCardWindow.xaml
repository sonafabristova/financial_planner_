<Window x:Class="financial_planner.View.GoalCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка цели" 
        Height="550" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Background="#E3F2FD">
        <StackPanel Margin="30">
            <!-- Заголовок -->
            <TextBlock Text="КАРТОЧКА ЦЕЛИ" 
                       FontSize="22" 
                       FontWeight="Bold" 
                       Foreground="#0D47A1" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,25"/>

            <!-- Основная информация -->
            <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <!-- Название -->
                    <TextBlock Text="НАЗВАНИЕ" FontSize="11" Foreground="#78909C"/>
                    <TextBlock x:Name="NameText" FontSize="18" FontWeight="Bold" 
                               Foreground="#0D47A1" Margin="0,5,0,15" TextWrapping="Wrap"/>

                    <!-- Описание -->
                    <TextBlock Text="ОПИСАНИЕ" FontSize="11" Foreground="#78909C"/>
                    <TextBlock x:Name="DescriptionText" FontSize="14" 
                               Foreground="#5C6BC0" Margin="0,5,0,15" 
                               TextWrapping="Wrap"/>

                    <!-- Статус -->
                    <TextBlock Text="СТАТУС" FontSize="11" Foreground="#78909C"/>
                    <Border x:Name="StatusBorder" CornerRadius="10" Padding="8,4" 
                            Margin="0,5,0,15" HorizontalAlignment="Left">
                        <TextBlock x:Name="StatusText" FontSize="12" FontWeight="SemiBold"/>
                    </Border>

                    <!-- Приоритет -->
                    <TextBlock Text="ПРИОРИТЕТ" FontSize="11" Foreground="#78909C"/>
                    <TextBlock x:Name="PriorityText" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#1565C0" Margin="0,5,0,15"/>

                    <!-- Процент отчислений -->
                    <TextBlock Text="ПРОЦЕНТ ОТЧИСЛЕНИЙ" FontSize="11" Foreground="#78909C"/>
                    <TextBlock x:Name="PercentageText" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#4CAF50" Margin="0,5,0,15"/>
                </StackPanel>
            </Border>

            <!-- Финансовая информация -->
            <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="ФИНАНСОВАЯ ИНФОРМАЦИЯ" FontSize="12" 
                               FontWeight="SemiBold" Foreground="#0D47A1" Margin="0,0,0,15"/>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Целевая сумма:" FontSize="13" Foreground="#78909C"/>
                        <TextBlock Grid.Column="1" x:Name="TargetAmountText" FontSize="15" FontWeight="Bold" Foreground="#F44336"/>

                        <TextBlock Grid.Column="0" Text="Накоплено:" FontSize="13" Foreground="#78909C" Margin="0,10,0,0"/>
                        <TextBlock Grid.Column="1" x:Name="CurrentAmountText" FontSize="15" FontWeight="Bold" Foreground="#4CAF50" Margin="0,10,0,0"/>

                        <TextBlock Grid.Column="0" Text="Осталось:" FontSize="13" Foreground="#78909C" Margin="0,10,0,0"/>
                        <TextBlock Grid.Column="1" x:Name="RemainingText" FontSize="15" FontWeight="Bold" Foreground="#FF9800" Margin="0,10,0,0"/>
                    </Grid>

                    <!-- Прогресс -->
                    <TextBlock Text="ПРОГРЕСС" FontSize="11" Foreground="#78909C" Margin="0,15,0,5"/>
                    <ProgressBar x:Name="ProgressBar" Height="10" Foreground="#42A5F5" Background="#E0E0E0"/>
                    <TextBlock x:Name="ProgressText" FontSize="12" Foreground="#5C6BC0" 
                               HorizontalAlignment="Right" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- История -->
            <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="ИСТОРИЯ" FontSize="12" FontWeight="SemiBold" 
                               Foreground="#0D47A1" Margin="0,0,0,10"/>

                    <TextBlock x:Name="CreatedDateText" FontSize="12" Foreground="#78909C"/>
                    <TextBlock x:Name="CompletedDateText" FontSize="12" Foreground="#78909C" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Кнопка закрытия (без CornerRadius) -->
            <Button Content="Закрыть" Width="120" Height="40" HorizontalAlignment="Center"
                    Background="#42A5F5" Foreground="White" BorderThickness="0"
                    FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                    Click="ButtonClose_Click"/>
        </StackPanel>
    </Grid>
</Window>