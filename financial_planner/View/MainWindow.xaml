<Window x:Class="financial_planner.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:financial_planner.ViewModels"
        WindowState="Maximized"
        WindowStyle="None"
        Title="Финансовый планировщик" Height="450" Width="800">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель -->
        <Grid Grid.Column="0" Background="#BBDEFB">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,40,0,0">
                <TextBlock Text="ФИНАНСЫ" FontSize="24" FontWeight="Bold" 
                           Foreground="#0D47A1" HorizontalAlignment="Center" 
                           Margin="0,20,0,30"/>

                <Button Content="Помощь" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding HelpCommand}"/>

                <Button Content="Мои цели" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding GoalsCommand}"/>

                <Button Content="Новая цель" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding NewGoalCommand}"/>

                <Button Content="Распределение" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding DistributionCommand}"/>

                <Button Content="Пополнить цель" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding TopUpGoalCommand}"/>

                <Rectangle Height="1" Margin="15,20,15,10" Fill="#90CAF9" Opacity="0.5"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,30">
                <Button Content="Выйти" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" BorderThickness="0"
                        HorizontalAlignment="Left" FontSize="14" Cursor="Hand"
                        Command="{Binding ExitCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Правая область -->
        <Grid Grid.Column="1" Background="#E3F2FD" Margin="20,25,25,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Приветствие -->
            <TextBlock Grid.Row="0" FontSize="22" FontWeight="SemiBold" 
                       Foreground="#0D47A1" Margin="0,0,0,15">
                Добро пожаловать, 
                <Run Text="{Binding UserName}" Foreground="#1565C0" FontWeight="Bold"/>
            </TextBlock>

            <!-- Статистика -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,25">
                <Border Background="White" CornerRadius="16" Padding="20,15" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="ДОХОД ЗА МЕСЯЦ" FontSize="11" Foreground="#78909C" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding MonthlyIncomeText}" 
                                   FontSize="28" FontWeight="Bold" Foreground="#2E7D32"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="16" Padding="20,15" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="РАСХОД ЗА МЕСЯЦ" FontSize="11" Foreground="#78909C" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding MonthlyExpensesText}" 
                                   FontSize="28" FontWeight="Bold" Foreground="#F44336"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="16" Padding="20,15">
                    <StackPanel>
                        <TextBlock Text="АКТИВНЫХ ЦЕЛЕЙ" FontSize="11" Foreground="#78909C" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ActiveGoalsCount}" 
                                   FontSize="32" FontWeight="Bold" Foreground="#0D47A1"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Кнопки доход/расход -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20">
                <Button Content="Внести доход" Width="150" Height="40"
                        Background="#4CAF50" Foreground="White" BorderThickness="0"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding AddIncomeCommand}"/>
                <Button Content="Внести расход" Width="150" Height="40" Margin="15,0,0,0"
                        Background="#F44336" Foreground="White" BorderThickness="0"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding AddExpenseCommand}"/>
                <Button Content="Сбросить месяц" Width="120" Height="40" Margin="15,0,0,0"
                        Background="#FF9800" Foreground="White" BorderThickness="0"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding ResetMonthCommand}"/>
            </StackPanel>

            <!-- Заголовок списка целей -->
            <StackPanel Grid.Row="3">
                <TextBlock Text="АКТИВНЫЕ ЦЕЛИ" FontSize="14" FontWeight="SemiBold" 
                           Foreground="#0D47A1" Margin="0,0,0,12"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ListBox ItemsSource="{Binding ActiveGoals}"
                             Background="Transparent" BorderThickness="0"
                             MouseDoubleClick="GoalsList_MouseDoubleClick"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="12" Padding="15,12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                                   Text="{Binding Name, Mode=OneWay}" 
                                                   FontWeight="Bold" FontSize="15"
                                                   Foreground="#0D47A1"
                                                   TextWrapping="Wrap"/>

                                        <Border Grid.Row="0" Grid.Column="1" 
                                                Background="#E3F2FD" CornerRadius="10" 
                                                Padding="8,3" Margin="10,0,0,0"
                                                Height="26">
                                            <TextBlock Text="{Binding Status.Name, Mode=OneWay}" 
                                                       FontSize="11" Foreground="#1976D2"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" 
                                                   Text="{Binding ProgressText, Mode=OneWay}" 
                                                   FontSize="12" Foreground="#5C6BC0"
                                                   Margin="0,8,0,5"/>

                                        <ProgressBar Grid.Row="2" Grid.ColumnSpan="2" 
                                                     Value="{Binding Progress, Mode=OneWay}" 
                                                     Maximum="100" Height="6" 
                                                     Foreground="#42A5F5" Background="#E0E0E0"/>

                                        <TextBlock Grid.Row="3" Grid.ColumnSpan="2" 
                                                   Text="{Binding DisplayName, Mode=OneWay}" 
                                                   FontSize="10" Foreground="#90A4AE"
                                                   Margin="0,10,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </StackPanel>
        </Grid>
    </Grid>
</Window>