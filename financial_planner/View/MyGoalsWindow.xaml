<Window x:Class="financial_planner.View.MyGoalsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:financial_planner.ViewModels"
        WindowState="Maximized"
        WindowStyle="None"
        Title="Мои цели" Height="450" Width="800">

    

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель навигации -->
        <Grid Grid.Column="0" Background="#BBDEFB">
            <StackPanel Margin="0,40,0,0">
                <TextBlock Text="ФИНАНСЫ" FontSize="20" FontWeight="Bold" 
                           Foreground="#0D47A1" HorizontalAlignment="Center" 
                           Margin="0,20,0,30"/>

                <Button Content="Помощь" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" 
                        BorderThickness="0" HorizontalAlignment="Left" 
                        FontSize="14" Cursor="Hand" Command="{Binding HelpCommand}"/>

                <Button Content="Внести доход" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" 
                        BorderThickness="0" HorizontalAlignment="Left" 
                        FontSize="14" Cursor="Hand" Command="{Binding AddIncomeCommand}"/>

                <Button Content="Внести расход" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" 
                        BorderThickness="0" HorizontalAlignment="Left" 
                        FontSize="14" Cursor="Hand" Command="{Binding AddExpenseCommand}"/>

                <Button Content="Новая цель" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" 
                        BorderThickness="0" HorizontalAlignment="Left" 
                        FontSize="14" Cursor="Hand" Command="{Binding NewGoalCommand}"/>

                <Button Content="Распределение" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" 
                        BorderThickness="0" HorizontalAlignment="Left" 
                        FontSize="14" Cursor="Hand" Command="{Binding DistributionCommand}"/>

                <Button Content="Назад" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" 
                        BorderThickness="0" HorizontalAlignment="Left" 
                        FontSize="14" Cursor="Hand" Command="{Binding BackCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>

                <Button Content="Выйти" Height="45" Margin="15,5" 
                        Background="Transparent" Foreground="#0D47A1" 
                        BorderThickness="0" HorizontalAlignment="Left" 
                        FontSize="14" Cursor="Hand" Command="{Binding ExitCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Правая область: список целей -->
        <Grid Grid.Column="1" Background="#E3F2FD" Margin="20,25,25,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0" Text="ВАШИ ЦЕЛИ" FontSize="24" FontWeight="Bold" 
                       Foreground="#0D47A1" HorizontalAlignment="Center" 
                       Margin="0,0,0,15"/>

            <!-- История целей (инфо-блок) -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" 
                    Padding="15,10" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="ИСТОРИЯ ЦЕЛЕЙ" FontSize="12" 
                               Foreground="#78909C" FontWeight="SemiBold"/>

                    <TextBlock FontSize="14" Foreground="#0D47A1" Margin="0,5,0,0">
                        Активных целей для накопления: 
                        <Run Text="{Binding ActiveGoalsCount}" FontWeight="Bold" Foreground="#1565C0"/>
                    </TextBlock>

                    <TextBlock FontSize="12" Foreground="#5C6BC0" Margin="0,3,0,0">
                        Всего накоплено: 
                        <Run Text="{Binding TotalSaved, Mode=OneWay, StringFormat={}{0:N0} ₽}" FontWeight="SemiBold"/>
                        из 
                        <Run Text="{Binding TotalTarget, Mode=OneWay, StringFormat={}{0:N0} ₽}"/>
                    </TextBlock>

                    <TextBlock FontSize="12" Foreground="#5C6BC0" Margin="0,3,0,0"
                               Text="{Binding TotalProgressText, Mode=OneWay, StringFormat=Прогресс: {0}}"/>
                </StackPanel>
            </Border>

            <!-- Список целей -->
            <StackPanel Grid.Row="2" Margin="0,0,0,10">
                <TextBlock Text="СПИСОК ЦЕЛЕЙ" FontSize="14" FontWeight="SemiBold" 
                           Foreground="#0D47A1" Margin="0,0,0,10"/>
            </StackPanel>

            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="GoalsListBox" 
                         Background="Transparent" 
                         BorderThickness="0"
                         ItemsSource="{Binding Goals}"
                         SelectedItem="{Binding SelectedGoal, Mode=TwoWay}"
                         MouseDoubleClick="GoalsListBox_MouseDoubleClick"
                         HorizontalContentAlignment="Stretch">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,0,0,8"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" 
                                    CornerRadius="12" 
                                    Padding="15,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Название цели -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               Text="{Binding Name, Mode=OneWay}" 
                                               FontWeight="Bold" FontSize="16"
                                               Foreground="#0D47A1"
                                               TextWrapping="Wrap"/>

                                    <!-- Статус -->
                                    <Border Grid.Row="0" Grid.Column="1" 
                                            Background="#E3F2FD" CornerRadius="10" 
                                            Padding="8,3" Margin="10,0,0,0"
                                            Height="26">
                                        <TextBlock Text="{Binding Status.Name, Mode=OneWay}" 
                                                   FontSize="11" Foreground="#1976D2"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Оставшаяся сумма / исходная сумма -->
                                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2" 
                                               FontSize="13" Foreground="#5C6BC0"
                                               Margin="0,8,0,5"
                                               TextWrapping="Wrap">
                                        Осталось: <Run Text="{Binding Remaining, Mode=OneWay, StringFormat={}{0:N0} ₽}" FontWeight="Bold"/>
                                        / <Run Text="{Binding TargetAmount, Mode=OneWay, StringFormat={}{0:N0} ₽}"/>
                                    </TextBlock>

                                    <!-- Процент накопления -->
                                    <TextBlock Grid.Row="2" Grid.ColumnSpan="2" 
                                               Text="{Binding ProgressText, Mode=OneWay}" 
                                               FontSize="12" Foreground="#1976D2"
                                               Margin="0,5,0,5"/>

                                    <!-- Прогресс-бар -->
                                    <ProgressBar Grid.Row="3" Grid.ColumnSpan="2" 
                                                 Value="{Binding Progress, Mode=OneWay}" 
                                                 Maximum="100" Height="8" 
                                                 Foreground="#42A5F5" Background="#E0E0E0"
                                                 Margin="0,5,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <!-- Кнопка пополнения -->
            <StackPanel Grid.Row="4" Margin="0,15,0,0">
                <Button Content="Внести сумму в накопления" 
                        Height="45" Width="220" HorizontalAlignment="Center"
                        Background="#4CAF50" Foreground="White" BorderThickness="0"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding TopUpGoalCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>