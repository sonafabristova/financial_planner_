<Window x:Class="financial_planner.View.TopUpGoalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пополнение цели" Height="500" Width="500"
        WindowStartupLocation="CenterOwner">

    <Grid Background="#E3F2FD">
        <StackPanel Margin="30">
            <TextBlock Text="ПОПОЛНЕНИЕ ЦЕЛИ" FontSize="20" FontWeight="Bold" 
                       Foreground="#0D47A1" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Цель:" FontWeight="Bold" Foreground="#0D47A1"/>
                    <TextBlock x:Name="GoalNameText" FontSize="14" Margin="0,5,0,0"/>
                    <TextBlock Text="Текущая сумма:" FontWeight="Bold" Foreground="#0D47A1" Margin="0,15,0,0"/>
                    <TextBlock x:Name="CurrentAmountText" FontSize="14" Margin="0,5,0,0"/>
                    <TextBlock Text="Целевая сумма:" FontWeight="Bold" Foreground="#0D47A1" Margin="0,15,0,0"/>
                    <TextBlock x:Name="TargetAmountText" FontSize="14" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Сумма пополнения" FontSize="14" Foreground="#0D47A1" Margin="0,0,0,5"/>
            <TextBox x:Name="AmountBox" Height="40" FontSize="14" Padding="10"
                     Background="White" BorderBrush="#42A5F5" BorderThickness="1"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                <Button Content="Пополнить" Width="120" Height="40"
                        Background="#4CAF50" Foreground="White" BorderThickness="0"
                        FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                        Click="ButtonSave_Click"/>
                <Button Content="Отмена" Width="100" Height="40" Margin="15,0,0,0"
                        Background="#90A4AE" Foreground="White" BorderThickness="0"
                        FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                        Click="ButtonCancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>