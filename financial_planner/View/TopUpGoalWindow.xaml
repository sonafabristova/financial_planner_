<Window x:Class="financial_planner.View.TopUpGoalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пополнение цели" 
        Height="620" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Background="#E3F2FD">
        <StackPanel Margin="25">
            <TextBlock Text="ПОПОЛНЕНИЕ ЦЕЛИ" 
                       FontSize="20" FontWeight="Bold" 
                       Foreground="#0D47A1" HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Цель:" FontWeight="Bold" Foreground="#0D47A1"/>
                    <TextBlock Text="{Binding GoalName}" FontSize="16" FontWeight="SemiBold" 
                               Foreground="#1565C0" Margin="0,5,0,10" TextWrapping="Wrap"/>

                    <TextBlock Text="Текущая сумма:" FontWeight="Bold" Foreground="#0D47A1" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding CurrentAmountText, Mode=OneWay}" FontSize="14" Foreground="#4CAF50" Margin="0,5,0,0"/>

                    <TextBlock Text="Целевая сумма:" FontWeight="Bold" Foreground="#0D47A1" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding TargetAmountText, Mode=OneWay}" FontSize="14" Foreground="#F44336" Margin="0,5,0,0"/>

                    <ProgressBar Value="{Binding Progress, Mode=OneWay}" Maximum="100" Height="8" 
                                 Foreground="#42A5F5" Background="#E0E0E0" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Сумма пополнения" FontSize="14" FontWeight="SemiBold" 
                       Foreground="#0D47A1" Margin="0,0,0,8"/>
            <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" 
                     Height="40" FontSize="16" Padding="10"
                     Background="White" BorderBrush="#42A5F5" BorderThickness="1"/>

            <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="Red" 
                       Margin="0,10,0,0" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                <Button Content="Пополнить" Width="130" Height="40"
                        Background="#4CAF50" Foreground="White" BorderThickness="0"
                        FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding TopUpCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                <Button Content="Отмена" Width="100" Height="40" Margin="15,0,0,0"
                        Background="#90A4AE" Foreground="White" BorderThickness="0"
                        FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>