<Window x:Class="financial_planner.View.TransactionArchiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Архив транзакций" 
        Height="600" 
        Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Background="#E3F2FD">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="АРХИВ ТРАНЗАКЦИЙ" 
                   FontSize="22" FontWeight="Bold" 
                   Foreground="#0D47A1" HorizontalAlignment="Center" 
                   Margin="0,20,0,20"/>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" Margin="20,0,20,10" Height="40">
            <TabItem Header="Доходы">
                <ListBox x:Name="IncomeList" Margin="10" 
                         Background="White" BorderBrush="#42A5F5" BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="20" Margin="0,0,10,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Category.Name}" FontWeight="Bold" Foreground="#0D47A1"/>
                                        <TextBlock Text="{Binding Note}" FontSize="11" Foreground="#78909C"/>
                                        <TextBlock Text="{Binding Date, StringFormat=dd.MM.yyyy HH:mm}" FontSize="10" Foreground="#90A4AE"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding DisplayAmount}" 
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="#4CAF50" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>

            <TabItem Header="Расходы">
                <ListBox x:Name="ExpenseList" Margin="10" 
                         Background="White" BorderBrush="#42A5F5" BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="20" Margin="0,0,10,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Category.Name}" FontWeight="Bold" Foreground="#0D47A1"/>
                                        <TextBlock Text="{Binding Note}" FontSize="11" Foreground="#78909C"/>
                                        <TextBlock Text="{Binding Date, StringFormat=dd.MM.yyyy HH:mm}" FontSize="10" Foreground="#90A4AE"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding DisplayAmount}" 
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="#F44336" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>

        <!-- Кнопка закрытия -->
        <Button Grid.Row="2" Content="Закрыть" Width="120" Height="35" 
                HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20"
                Background="#42A5F5" Foreground="White" BorderThickness="0"
                FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                Click="ButtonClose_Click"/>
    </Grid>
</Window>